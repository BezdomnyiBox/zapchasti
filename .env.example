# ========== Docker Compose: PostgreSQL ==========
POSTGRES_USER=zapchasti
POSTGRES_PASSWORD=zapchasti
POSTGRES_DB=zapchasti

# ========== Docker Compose: MinIO ==========
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ========== Backend (при запуске в Docker — хост db/redis/minio) ==========
# Для локального запуска backend на хосте скопируйте backend/.env.example в backend/.env
# и поднимайте только: docker-compose up -d db redis
DATABASE_URL=postgresql://zapchasti:zapchasti@db:5432/zapchasti
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=zapchasti
