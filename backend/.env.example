# База данных PostgreSQL
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://zapchasti:zapchasti@localhost:5432/zapchasti

# Redis (для rate limiting и кэша)
REDIS_URL=redis://localhost:6379/0

# Секрет для JWT (сгенерировать: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-in-production

# JWT (опционально)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# S3-совместимое хранилище (MinIO для локальной разработки или AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=zapchasti
