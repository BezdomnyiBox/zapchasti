# ===========================================
# PostgreSQL (сервис db в docker-compose)
# ===========================================
POSTGRES_USER=zapchasti
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=zapchasti

# Backend: URL к БД (хост db = имя сервиса в docker-compose)
DATABASE_URL=postgresql://zapchasti:change_me_strong_password@db:5432/zapchasti

# ===========================================
# Redis (сервис redis)
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# MinIO (сервис minio), S3-совместимое хранилище
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio_password
S3_BUCKET=uploads

# ===========================================
# Backend / Auth (JWT)
# ===========================================
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_generate_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
